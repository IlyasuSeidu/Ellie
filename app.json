{
  "expo": {
    "name": "Ellie: Miner Shift Assistant",
    "slug": "ellie",
    "scheme": "ellie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "googleServicesFile": "./ios/Ellie/GoogleService-Info.plist",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Ellie needs speech recognition to understand your questions.",
        "NSMicrophoneUsageDescription": "Ellie needs microphone access for voice commands."
      },
      "bundleIdentifier": "com.ellie.minershiftassistant"
    },
    "android": {
      "package": "com.ellie.minershiftassistant",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "expo-asset",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.197162533368-5mhtc7pnngbq2n50rll6857n90n3t97r"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ellie needs access to your photos to set a profile picture.",
          "cameraPermission": "Ellie needs access to your camera to take a profile picture."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Ellie needs microphone access for voice commands.",
          "speechRecognitionPermission": "Ellie needs speech recognition to understand your questions."
        }
      ]
    ]
  }
}
