{
  "name": "ellie",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:visual": "jest --runInBand --silent --testPathPattern=visual\\.test\\.tsx$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "detox test --configuration ios.release",
    "test:e2e:android": "detox test --configuration android.release",
    "test:e2e:build:ios": "detox build --configuration ios.release",
    "test:e2e:build:android": "detox build --configuration android.release",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint",
    "prepare": "husky",
    "process-icons": "node scripts/process-icons.js",
    "backend:build": "npm --prefix backend/functions run build",
    "release:check": "npm run type-check && npm test -- --runInBand --silent && npm run backend:build",
    "firebase:projects": "firebase projects:list",
    "firebase:emulators:functions": "firebase emulators:start --config firebase.json --only functions",
    "firebase:deploy:functions": "firebase deploy --config firebase.json --only functions"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@picovoice/porcupine-react-native": "^4.0.0",
    "@picovoice/react-native-voice-processor": "^1.2.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "dayjs": "^1.11.19",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.14",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-localization": "~17.0.8",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.0",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.8",
    "expo-updates": "~29.0.14",
    "firebase": "^11.10.0",
    "i18next": "^25.8.17",
    "lottie-react-native": "^7.3.5",
    "react": "19.1.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.14.5",
    "react-native-purchases": "^9.12.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.10",
    "detox": "^20.46.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-tools": "^14.24.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^15.2.12",
    "prettier": "^3.8.1",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
