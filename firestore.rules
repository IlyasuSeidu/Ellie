rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsShiftLogId(logId) {
      return isSignedIn() && logId.matches('^' + request.auth.uid + ':.*$');
    }

    // Users: only the authenticated owner can access their document.
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // Notifications: must belong to the authenticated user via userId field.
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // Shift logs: allow first-time owner reads by owned document id as well as by stored userId.
    match /shiftLogs/{logId} {
      allow read, update, delete: if ownsShiftLogId(logId)
        || (isSignedIn() && resource != null && resource.data.userId == request.auth.uid);
      allow create: if ownsShiftLogId(logId)
        && request.resource.data.userId == request.auth.uid;
    }

    // Sleep logs: nested under user scope.
    match /sleepLogs/{userId}/entries/{entryId} {
      allow read, write: if isOwner(userId);
    }

    // Analytics and AI intelligence are written by Cloud Functions only.
    // Admin SDK bypasses rules; direct client access stays denied by design.
    match /analyticsEvents/{eventId} {
      allow read, write: if false;
    }

    match /analyticsRealtimeDaily/{dayId} {
      allow read, write: if false;
    }

    match /analyticsDailySummaries/{summaryId} {
      allow read, write: if false;
    }

    match /aiDecisionQueue/{decisionId} {
      allow read, write: if false;
    }

    match /aiDailyAnalyses/{analysisId} {
      allow read, write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
